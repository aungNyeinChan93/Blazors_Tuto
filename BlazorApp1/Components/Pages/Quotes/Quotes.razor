@page "/quotes/index"


<div>
    <h4>Quotes</h4>
    <img src="/images/straw.jpg" class="rounded-circle" />

    <a href="/quotes/create" class="btn btn-primary ms-4">Create</a>

    @if (quotes is not null || quotes!.Count >=1)
    {
        @foreach (var quote in quotes)
        {
            <div class="card card-body my-2 border border-info">
                <p>@quote.Name</p>
                <p>@quote.Author</p>
                <div class="d-flex">
                    <a href="/quotes/detail/@quote.QuoteId" class="btn btn-info mx-2 ">Detail</a>
                    <a href="/quotes/edit/@quote.QuoteId" class="btn btn-outline-secondary mx-2 ">Edit</a>
                    <EditForm Model="quote" FormName="@($"delete-quote-{quote.QuoteId}")" OnValidSubmit="()=>Delete(quote.QuoteId)">
                        <button  type="submit" class="btn btn-danger mx-2">Delete</button>
                    </EditForm>
                </div>
            </div>  
        }   
    }
</div>

@code{

    public List<Quote> quotes = QuoteRepo.AllQuotes();

    public void Delete(int id)
    {
        QuoteRepo.DeleteQuote(id);
        quotes = QuoteRepo.AllQuotes(); 
    }
}