@page "/authors"

@inject AuthorService AuthorService;
@inject NavigationManager NavigationManager;

<h3>Authors</h3>

<div>
    <a href="/authors/create" class="btn btn-primary p-2 my-2"> Create </a>
</div>

@if (authors is not null)
{
    <div class="mx-auto container">
        <ul class="list-group">
            @foreach (var author in authors)
            {
                <li class="list-group-item d-flex justify-content-between">
                    <a href="/authors/detail/@author.AuthorId" class=" btn btn-link">@author.Name</a>
                    <div class="d-flex mx-1">
                        <a href="/authors/@author.AuthorId/todos" class=" btn btn-link">Todos</a>
                        
                        <EditForm OnValidSubmit=" () => DeleteAuthor(author.AuthorId)"
                            Model="author" FormName="@($"delete-author-{author.AuthorId}")">
                            <button type="submit" class="btn btn-danger">Delete</button>
                        </EditForm>
                    </div>
                </li>
                
            }
        </ul>
    </div>
}

@code {
    // [Inject]
    // private AuthorService authService { get; set; } = default!;

    private List<Author>? authors { get; set; }

    protected override async Task OnInitializedAsync()
    {
        authors ??= await AuthorService.GetAllAsync();
    }

    private async Task DeleteAuthor(int id)
    {
        var res = await AuthorService.DeleteAsync(id);
        if (res)
        {
            NavigationManager.Refresh();
        }
    }

}
