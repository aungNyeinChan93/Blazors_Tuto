@page "/authors"

@inject AuthorService AuthorService;

<h3>Authors</h3>

<div>
    <a href="/authors/create" class="btn btn-primary p-2 my-2"> Create </a>
</div>

@if (authors is not null)
{
    <div class="mx-auto container">
        <ul class="list-group">
            @foreach (var author in authors)
            {
                <li class="list-group-item">
                    <a href="/authors/detail/@author.AuthorId" class=" btn btn-link">@author.Name</a>
                </li>
                
            }
        </ul>
    </div>
}

@code {
    // [Inject]
    // private AuthorService authService { get; set; } = default!;

    private List<Author>? authors { get; set; }

    protected override async Task OnInitializedAsync()
    {
        authors ??= await AuthorService.GetAllAsync();
    }


}
