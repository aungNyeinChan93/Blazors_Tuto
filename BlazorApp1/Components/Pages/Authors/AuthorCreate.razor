@page "/authors/create"

@inject NavigationManager NavigationManager;
@inject AuthorService AuthorService;


<div class=" mx-auto container">

    @if (author is not null)
    {
        <div class="col-6">
            <h4 class="text-primary">Crate Author</h4>
            <EditForm Model="author" FormName="CrateAuthor" class="border border-info p-4 rounded" OnValidSubmit="CreateSubmit">
                <DataAnnotationsValidator></DataAnnotationsValidator>
                <ValidationSummary></ValidationSummary>
        
                <div class="my-2">
                    <label for="Name" class="form-label text-success">Name</label>
                    <InputText id="Name" class="form-control" @bind-Value="author.Name">Name</InputText>
                    <ValidationMessage For="() => author.Name"></ValidationMessage>
                </div>
       
                <div class="my-2">
                    <button type="submit" class="btn btn-outline-primary w-25 mt-3">Create </button>
                    <a href="/authors" class="btn btn-outline-secondary w-25 mt-3">Back </a>
                </div>

                @* <InputNumber @bind-Value="author.AuthorId" hidden /> *@
        
            </EditForm>
        </div>
    }

</div>


@code{
    [SupplyParameterFromForm(FormName = "CrateAuthor")]
    public Author? author { get; set; } = new Author(){Name = ""};

    private async Task CreateSubmit()
    {   
        if (author is not null)
        {
            var result = await AuthorService.CreateAsync(author);
            if (result is not null)
            {
                NavigationManager.NavigateTo("/authors");
            }
        }
    }

}