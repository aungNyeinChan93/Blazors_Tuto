@inject NavigationManager NavigationManager;


<div class="@(!todo!.IsStatus ? "bg-danger" : "bg-success") card my-2">
    <h5 class="card-header">@todo!.Title</h5>
    <div class="card-body">
        <h5 class="card-title">Special title treatment</h5>
        <p class="card-text">With supporting text below as a natural lead-in to additional content.</p>
        <button type="button" @onclick="ChangeStatus" class="btn btn-primary">Change Status</button>
    </div>
</div>


@code {
    public Todo? todo { get; set; } = new Todo { Title = "", IsStatus = false };

    private void ChangeStatus()
    {
        if (todo is not null)
        {
            this.todo.IsStatus = !todo.IsStatus;        
        }
    }

}
